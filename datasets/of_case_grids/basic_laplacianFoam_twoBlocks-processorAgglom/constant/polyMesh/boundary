FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

7
(
    AMI1
    {
        type            cyclicAMI;
        inGroups        1(cyclicAMI);
        nFaces          3;
        startFace       16;
        matchTolerance  0.0001;
        transform       noOrdering;
        neighbourPatch  AMI2;
        AMIMethod       faceAreaWeightAMI;
        restartUncoveredSourceFace 1;
    }
    AMI2
    {
        type            cyclicAMI;
        inGroups        1(cyclicAMI);
        nFaces          2;
        startFace       19;
        matchTolerance  0.0001;
        transform       noOrdering;
        neighbourPatch  AMI1;
        AMIMethod       faceAreaWeightAMI;
        restartUncoveredSourceFace 1;
    }
    top
    {
        type            patch;
        nFaces          5;
        startFace       21;
    }
    bottom
    {
        type            patch;
        nFaces          5;
        startFace       26;
    }
    left
    {
        type            patch;
        nFaces          3;
        startFace       31;
    }
    right
    {
        type            patch;
        nFaces          2;
        startFace       34;
    }
    frontAndBack
    {
        type            empty;
        inGroups        1(empty);
        nFaces          26;
        startFace       36;
    }
)

