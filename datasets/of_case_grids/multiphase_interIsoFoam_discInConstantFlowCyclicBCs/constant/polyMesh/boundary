FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    left
    {
        type            cyclic;
        inGroups        1(cyclic);
        nFaces          50;
        startFace       4900;
        matchTolerance  0.0001;
        transform       unknown;
        neighbourPatch  right;
    }
    right
    {
        type            cyclic;
        inGroups        1(cyclic);
        nFaces          50;
        startFace       4950;
        matchTolerance  0.0001;
        transform       unknown;
        neighbourPatch  left;
    }
    top
    {
        type            cyclic;
        inGroups        1(cyclic);
        nFaces          50;
        startFace       5000;
        matchTolerance  0.0001;
        transform       unknown;
        neighbourPatch  bottom;
    }
    bottom
    {
        type            cyclic;
        inGroups        1(cyclic);
        nFaces          50;
        startFace       5050;
        matchTolerance  0.0001;
        transform       unknown;
        neighbourPatch  top;
    }
    front
    {
        type            empty;
        inGroups        1(empty);
        nFaces          2500;
        startFace       5100;
    }
    back
    {
        type            empty;
        inGroups        1(empty);
        nFaces          2500;
        startFace       7600;
    }
)

